
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to read their own document in the allowedUsers collection
    // to check their role. The document ID is the user's email.
    match /allowedUsers/{userEmail} {
      allow read: if request.auth != null && request.auth.token.email == userEmail;
    }

    // Server-side flows using the Admin SDK will bypass these rules.
    // Client-side access to the 'calls' collection is not needed.
    match /calls/{callId} {
      allow read, write: if false;
    }
  }
}
