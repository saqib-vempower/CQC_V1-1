rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read their own document in allowedUsers collection
    // This is used to check for roles (e.g., admin, qa_reviewer)
    match /allowedUsers/{userEmail} {
      allow read: if request.auth != null && request.auth.token.email == userEmail;
    }

    // Disallow all other reads/writes by default on the client
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
