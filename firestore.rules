
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow read/write access to all users on the 'calls' collection
    match /calls/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Secure the allowedUsers collection
    match /allowedUsers/{email} {
      // Allow read access if the user is authenticated (i.e., any logged-in user)
      // This is needed for the client-side role check.
      allow read: if request.auth != null;
      
      // Allow a backend service account to read the list for validation.
      // This rule assumes your backend operates with a service account.
      // Firebase automatically provides a token to Admin SDKs which makes request.auth null.
      // `request.auth.token.firebase.sign_in_provider` will not be 'custom' for service accounts.
      allow get: if request.auth == null;

      // Disallow write access from the client to prevent tampering.
      allow write: if false;
    }
  }
}
