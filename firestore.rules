rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get user's role from the 'allowedUsers' collection.
    // The resource.data object contains the document's fields.
    function getUserRole(email) {
      return get(/databases/$(database)/documents/allowedUsers/$(email)).data.role;
    }
    
    // Helper function to check if a user is an admin.
    function isAdmin(email) {
      return getUserRole(email) == 'admin';
    }

    // Rules for the 'allowedUsers' collection.
    match /allowedUsers/{email} {
      // Only admins can read or write to the allowed users list.
      allow read, write: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // Rules for the 'calls' collection.
    match /calls/{callId} {
      // Admins and QA Reviewers can read call records.
      allow read: if request.auth != null && (getUserRole(request.auth.token.email) == 'admin' || getUserRole(request.auth.token.email) == 'qa_reviewer');
      
      // Only admins can create, update, or delete call records.
      allow write: if request.auth != null && isAdmin(request.auth.token.email);
    }
  }
}