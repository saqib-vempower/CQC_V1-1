rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default to locked down
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Allow a user to be created via our secure API route.
      allow create: if true;
      // Allow a logged-in user to read their own document.
      allow read: if request.auth.uid == userId;
      // Admins can update any user's role.
      allow update: if request.auth.token.role == 'Admin';
    }

    // Rules for the 'audits' collection
    match /audits/{auditId} {
      // Allow authenticated Admins or QA users to create new audit documents.
      // This rule now checks the custom claim, which is much faster.
      allow create: if request.auth.uid != null && (
        request.auth.token.role == 'Admin' ||
        request.auth.token.role == 'QA'
      );

      // Allow any authenticated user to read the audit data.
      allow read: if request.auth.uid != null;

      // Restrict updates and deletes to backend functions or Admins.
      allow update, delete: if request.auth.token.role == 'Admin';
    }
  }
}
