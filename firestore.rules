rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow logged-in users to read their own document in 'allowedUsers'
    // This is used by the client to check roles for UI purposes.
    match /allowedUsers/{email} {
       allow read: if request.auth != null && request.auth.token.email == email;
       allow write: if false; // Only allow writes from server-side admin SDK
    }

    // Allow admins/reviewers to read signup requests
    match /signupRequests/{docId} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)).data.role in ['admin', 'qa_reviewer'];
      allow write: if false; // Only allow writes from server-side admin SDK
    }

    // Allow authenticated server-side processes to write call records
    match /calls/{callId} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)).data.role in ['admin', 'qa_reviewer'];
      allow write: if false; // Block client-side writes
    }
  }
}
