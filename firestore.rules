rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read the list of allowed users to check roles.
    // Writes should be restricted to admin actions from a secure backend environment.
    match /allowedUsers/{userId} {
      allow read: if request.auth != null;
      allow write: if false; // Disallow client-side writes
    }

    // Allow authenticated users to create call records,
    // but only allow admins/reviewers (via backend logic) to read all of them.
    match /calls/{callId} {
      allow read, write: if request.auth != null;
    }
  }
}
