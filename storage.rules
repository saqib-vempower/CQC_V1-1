rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow reads and writes for all authenticated users.
    // In a production app, you would have more restrictive rules,
    // for example, only allowing a user to write to their own folder.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
