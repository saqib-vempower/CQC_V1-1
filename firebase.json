{
  "functions": {
    "source": "_firebase/functions",
    "runtime": "nodejs20",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "apphosting": {
    "backendId": "ssrcallqualitycompassxb",
    "region": "us-central1",
    "cloudFunctions": [
      "onCallUpload",
      "onAiTranscripting",
      "onAiAuditing",
      "onLogin"
    ]
  }
}
