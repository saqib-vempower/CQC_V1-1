{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "frameworksBackend": {
      "region": "us-central1",
      "secretEnvironmentVariables": [
        "APP_FIREBASE_PROJECT_ID",
        "APP_FIREBASE_CLIENT_EMAIL",
        "APP_FIREBASE_PRIVATE_KEY"
      ]
    }
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "runtime": "nodejs20",
      "region": "asia-south1",
      "predeploy": [
        "npm --prefix functions run build"
      ]
    }
  ]
}
